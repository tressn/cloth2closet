// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  DRESSMAKER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  FIT_SAMPLE_SENT
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  REQUIRES_PAYMENT_METHOD
  REQUIRES_CONFIRMATION
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  CANCELED
  FAILED
  REFUNDED
}

enum MilestoneStatus {
  PENDING
  INVOICED
  PAID
  RELEASED
  CANCELED
  REFUNDED
}

enum TransferStatus {
  PENDING
  PAID_OUT
  FAILED
  REVERSED
}

enum AttireType {
  DRESS
  SUIT
  TOP
  SKIRT
  PANTS
  OUTERWEAR
  TRADITIONAL
  OTHER
  BRIDAL
  EVENINGWEAR
}

enum DressmakerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountStatus {
  PENDING_EMAIL_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum NotificationType {
  QUOTE_REQUESTED
  QUOTE_APPROVED
  PAYMENT_SUCCEEDED
  PROJECT_UPDATE
  SUPPORT_TICKET_CREATED
  PAYMENT_REFUNDED
  DISPUTE_OPENED
}

enum LabelStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupportCategory {
  ACCOUNT_ROLE
  PAYMENTS
  DISPUTE
  TECHNICAL
  OTHER
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum MilestoneType {
  DEPOSIT
  FINAL
}

enum LabelScope {
  PROJECT
  PORTFOLIO
  SPECIALTY
}

//// CORE MODELS ////

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  username     String? @unique
  passwordHash String?
  passwordResetTokens PasswordResetToken[]

  termsAcceptedAt      DateTime?
  termsAcceptedVersion String?

  role Role?

  sessions Session[]

  // Optional 1:1 profiles (only one will usually exist depending on role)
  customerProfile   CustomerProfile?   @relation("UserCustomerProfile")
  dressmakerProfile DressmakerProfile? @relation("UserDressmakerProfile")

  // Relations
  sentMessages Message[]

  // Projects where this user is the customer
  customerProjects   Project[] @relation("CustomerProjects")
  // Projects where this user is the dressmaker
  dressmakerProjects Project[] @relation("DressmakerProjects")

  // Conversations
  customerConversations   Conversation[] @relation("CustomerConversations")
  dressmakerConversations Conversation[] @relation("DressmakerConversations")

  // Measurements
  measurements Measurement[]

  //Reviews
  reviews Review[] @relation("UserReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileAssets FileAsset[]

  status              AccountStatus       @default(PENDING_EMAIL_VERIFICATION)
  approvedDressmakers DressmakerProfile[] @relation("DressmakerApprovedBy")

  // Creates and allows for notification of new conversations
  conversationReads ConversationRead[]

  //Allow for saved dressmakers
  savedDressmakers SavedDressmaker[]
  notifications    Notification[]

  //sketch Submission
  sketchSubmissionsMade     SketchSubmission[] @relation("SketchSubmittedBy")
  sketchSubmissionsApproved SketchSubmission[] @relation("SketchApprovedBy")
  labels                    Label[]
  supportTickets            SupportTicket[]
  adminActionLogs           AdminActionLog[]
}

model CustomerProfile {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation("UserCustomerProfile", fields: [userId], references: [id], onDelete: Cascade)

  // Example starter fields (optional but common)
  fullName        String?
  phone           String?
  timezoneIana    String?
  address1        String?
  address2        String?
  postalCode      String?
  countryCode     String? // "US", "CA", "GB", "FR"...
  subdivisionCode String? // "NY", "ON", "ENG"...

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DressmakerProfile {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation("UserDressmakerProfile", fields: [userId], references: [id], onDelete: Cascade)

  // “detailed attributes”
  displayName     String?
  bio             String?
  timezoneIana    String?
  countryCode     String? // "US", "CA", "GB", "FR"
  languages       String[] // Postgres array: ["en", "es"]
  basePriceFrom   Int? // store cents? or whole currency units (see note below)
  currency        String         @default("USD")
  yearsExperience Int?
  websiteUrl      String?
  instagramHandle String?
  socialLinks     Json?
  payoutProfile   PayoutProfile?

  // Portfolio items
  portfolioItems PortfolioItem[]

  // Saved dressmaker
  savedBy SavedDressmaker[]

  //for better labeling
  dressmakerSpecialties DressmakerSpecialty[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isPublished Boolean  @default(false)
  isPaused    Boolean  @default(false)

  // NEW: approval gate
  approvalStatus  DressmakerApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedById    String?
  approvedBy      User?                    @relation("DressmakerApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectionReason String?
}

model PayoutProfile {
  id                  String            @id @default(cuid())
  dressmakerProfileId String            @unique
  dressmakerProfile   DressmakerProfile @relation(fields: [dressmakerProfileId], references: [id], onDelete: Cascade)

  provider String @default("STRIPE") // STRIPE | PAYONEER later

  // Stripe Connect
  stripeAccountId String? @unique

  // Optional: store readiness snapshot
  payoutsEnabled   Boolean @default(false)
  detailsSubmitted Boolean @default(false)
  requirementsJson Json?

  // Payoneer (fallback later)
  payoneerEmail String?
  payoneerId    String?

  legalName       String?
  countryCode     String?
  subdivisionCode String?
  address1        String?
  address2        String?
  city            String?
  postalCode      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortfolioItem {
  id           String @id @default(cuid())
  dressmakerId String

  dressmaker DressmakerProfile @relation(fields: [dressmakerId], references: [id], onDelete: Cascade)

  title      String
  attireType AttireType @default(OTHER)
  imageUrls  String[] // ["https://...","https://..."]

  // optional: extra metadata
  description String?
  isFeatured  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileAssets FileAsset[]

  portfolioItemLabels PortfolioItemLabel[]

  @@index([dressmakerId])
}

model Project {
  id          String        @id @default(cuid())
  projectCode String        @unique
  title       String?
  status      ProjectStatus @default(REQUESTED)

  customerId   String
  dressmakerId String

  customer   User @relation("CustomerProjects", fields: [customerId], references: [id], onDelete: Restrict)
  dressmaker User @relation("DressmakerProjects", fields: [dressmakerId], references: [id], onDelete: Restrict)

  details    ProjectDetails?
  payment    Payment?
  milestones Milestone[]
  review     Review?

  // Conversations can optionally link to a project
  conversations Conversation[]

  // Quote
  quotedTotalAmount Int?
  currency          String @default("USD")

  //Deposit Percentage
  depositPercent Int? // 25..75 chosen by dressmaker when approving quote

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileAssets             FileAsset[]
  notifications          Notification[]
  projectMeasurementGate ProjectMeasurementGate?
  sketchSubmission       SketchSubmission?
  projectShipping        ProjectShipping?
  projectLabels          ProjectLabel[]
  supportTickets         SupportTicket[]

  @@index([customerId])
  @@index([dressmakerId])
  @@index([status])
}

model ProjectDetails {
  id        String @id @default(cuid())
  projectId String @unique

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  eventDate        DateTime?
  shipByDate       DateTime?
  fabricNotes      String?
  referenceImages  String[] // Postgres array URLs
  fabricAgreed     Boolean   @default(false)
  fabricAgreedNote String?

  requireSketch Boolean  @default(false)

  isRush      Boolean @default(false)
  wantsCalico Boolean @default(false)

  dressmakerPrivateNotes String?

  // ✅ NEW: gates for workflow
  sketchSubmittedAt DateTime?
  sketchApprovedAt  DateTime?

  measurementsRequested               String[] // e.g. ["inseam","sleeveLength"]
  measurementsConfirmedByDressmakerAt DateTime?
  measurementsConfirmedByCustomerAt   DateTime?

  fitSampleSentAt     DateTime? // dressmaker says “sent”
  fitSampleReceivedAt DateTime? // customer confirms “received”

  finalImages      String[]
  finalSubmittedAt DateTime?
  finalApprovedAt  DateTime?

  completedAt  DateTime?
  canceledAt   DateTime?
  cancelReason String?

  // optional: structured fields you’ll likely want later
  colorPreferences String?
  sizeNotes        String?
  budgetCeiling    Int? // again consider cents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Measurement {
  id         String @id @default(cuid())
  customerId String

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // flexible schema for measurements (bust/waist/hips/etc) without constant migrations
  fieldsJson Json

  // “latest measurement set” can be determined by updatedAt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

model ProjectMeasurementGate {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // dressmaker requests / checklist
  requestedFields       String[] // ["inseam", "sleeveLength"]
  dressmakerConfirmedAt DateTime?

  // customer confirms they updated measurements
  customerConfirmedAt DateTime?

  snapshotFieldsJson Json?
  lockedAt           DateTime?
  sourceMeasurementId String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// MESSAGING ////

model Conversation {
  id           String  @id @default(cuid())
  customerId   String
  dressmakerId String
  projectId    String? @unique
  isGeneral    Boolean @default(false)

  customer   User     @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Restrict)
  dressmaker User     @relation("DressmakerConversations", fields: [dressmakerId], references: [id], onDelete: Restrict)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  messages Message[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  conversationReads ConversationRead[]

  // Prevent accidental duplicate conversations for same pair + same project
  @@unique([customerId, dressmakerId, projectId])
  @@index([customerId])
  @@index([dressmakerId])
  @@index([projectId])
}

model Message {
  id             String @id @default(cuid())
  conversationId String
  senderId       String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  text        String?
  attachments String[] // S3 URLs later (optional)
  files       FileAsset[]

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model ConversationRead {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

//// PAYMENTS ////

model Payment {
  id          String        @id @default(cuid())
  projectId   String        @unique
  totalAmount Int // recommended: store in cents
  currency    String        @default("USD")
  status      PaymentStatus @default(REQUIRES_PAYMENT_METHOD)

  stripePaymentIntentId   String? @unique
  stripeCheckoutSessionId String? // for Stripe Checkout

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Milestone {
  id        String @id @default(cuid())
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type   MilestoneType
  title  String
  amount Int
  status MilestoneStatus @default(PENDING)
  dueAt  DateTime?

  // Stripe identifiers per milestone charge
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  // When we are allowed to pay out (for final: dispute window delay)
  payoutEligibleAt DateTime?
  paidAt           DateTime?
  releasedAt       DateTime?

  // Transfer (1:1 optional) — you already have this
  transfer Transfer?

  platformFeeAmount Int?   // your fee for this milestone
  shippingAmount    Int?   // only used when shipping is included in this milestone
  transferGroup     String? // Stripe reconciliation key

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, type])
  @@index([projectId])
  @@index([status])
  @@index([payoutEligibleAt])
}

model Transfer {
  id               String         @id @default(cuid())
  milestoneId      String         @unique
  stripeTransferId String?        @unique
  status           TransferStatus @default(PENDING)

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// REVIEWS ////

model Review {
  id        String @id @default(cuid())
  projectId String @unique

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  rating    Int // 1..5 (validate in app)
  text      String?
  photoUrls String[] // Postgres array URLs

  authorId String
  author   User   @relation("UserReviews", fields: [authorId], references: [id], onDelete: Restrict)

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileAssets FileAsset[]
}

enum FilePurpose {
  MESSAGE_ATTACHMENT
  PROJECT_REFERENCE
  PORTFOLIO_IMAGE
  REVIEW_PHOTO
}

model FileAsset {
  id       String  @id @default(cuid())
  url      String // where the file actually lives (S3, Cloudinary, etc.)
  mimeType String?
  fileName String?
  byteSize Int?

  purpose FilePurpose

  // Who uploaded the file
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  // Optional links (a file can belong to ONE of these)
  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  portfolioItemId String?
  portfolioItem   PortfolioItem? @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)

  reviewId String?
  review   Review? @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([projectId])
  @@index([messageId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedDressmaker {
  id String @id @default(cuid())

  customerId          String
  dressmakerProfileId String

  customer          User              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  dressmakerProfile DressmakerProfile @relation(fields: [dressmakerProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([customerId, dressmakerProfileId])
  @@index([customerId])
  @@index([dressmakerProfileId])
}

// For notification page 
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

//Sketch Submission
model SketchSubmission {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  submittedById String
  submittedBy   User   @relation("SketchSubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)

  imageUrls String[]
  note      String?

  approvedAt   DateTime?
  approvedById String?
  approvedBy   User?     @relation("SketchApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submittedById])
  @@index([approvedById])
}

//Shipping
model ProjectShipping {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  carrier        ShippingCarrier? @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  carrierId      String?
  carrierOther   String?
  trackingNumber String?
  shippedAt      DateTime?
  quotedAmount   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortfolioItemLabel {
  id              String @id @default(cuid())
  portfolioItemId String
  labelId         String

  portfolioItem PortfolioItem @relation(fields: [portfolioItemId], references: [id], onDelete: Cascade)
  label         Label         @relation(fields: [labelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([portfolioItemId, labelId])
  @@index([labelId])
  @@index([portfolioItemId])
}

model DressmakerSpecialty {
  id                  String @id @default(cuid())
  dressmakerProfileId String
  labelId             String

  dressmakerProfile DressmakerProfile @relation(fields: [dressmakerProfileId], references: [id], onDelete: Cascade)
  label             Label             @relation(fields: [labelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([dressmakerProfileId, labelId])
  @@index([labelId])
  @@index([dressmakerProfileId])
}

model Label {
  id String @id @default(cuid())

  // display text
  name String

  // normalized key for uniqueness
  slug   String
  scope  LabelScope  @default(PROJECT)
  status LabelStatus @default(PENDING)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectLabels         ProjectLabel[]
  portfolioItemLabels   PortfolioItemLabel[]
  dressmakerSpecialties DressmakerSpecialty[]

  @@unique([scope, slug])
  @@index([scope, status])
}

model ProjectLabel {
  id        String @id @default(cuid())
  projectId String
  labelId   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([projectId, labelId])
  @@index([projectId])
}

//support tickets
model SupportTicket {
  id             String  @id @default(cuid())
  userId         String?
  user           User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  requesterEmail String? // required for guests

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  category       SupportCategory
  subject        String
  message        String
  attachmentUrls String[]

  status SupportStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AdminActionLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String
  meta      Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([entity, entityId])
  @@index([adminId, createdAt])
}

model ShippingCarrier {
  id        String  @id @default(cuid())
  name      String  @unique // "UPS", "USPS", "DHL"
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projectShippings ProjectShipping[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
